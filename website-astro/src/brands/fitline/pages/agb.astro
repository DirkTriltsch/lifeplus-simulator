import LegalAgbDefault from '@shared/components/sections/LegalAgbDefault.astro';
import { getBrand } from '@shared/lib/brand';
import { contact } from '@shared/lib/contact';

const brand = await getBrand('fitline');
---
<LegalPageLayout brand={brand} title="AGB">
  <LegalAgbDefault brand={brand} contact={contact} source="shared/lib/contact.ts" />
</LegalPageLayout>
