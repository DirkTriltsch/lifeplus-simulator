---
import BrandLayout from '@shared/components/layout/BrandLayout.astro';
import PreviewBanner from '@shared/components/preview/PreviewBanner.astro';
import AccountPageDefault from '@shared/components/sections/AccountPageDefault.astro';
import { getBrand } from '@shared/lib/brand';

const brand = await getBrand('fitline');
---
<BrandLayout brand={brand} title="Preview: Mein Konto">
  <PreviewBanner brandId="fitline" component="AccountPageDefault.astro" livePage="/mein-konto.html" />
  <AccountPageDefault brand={brand} source="shared/components/sections/AccountPageDefault.astro" />
</BrandLayout>
