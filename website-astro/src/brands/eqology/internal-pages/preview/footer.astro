---
import BrandLayout from '@shared/components/layout/BrandLayout.astro';
import Footer from '@shared/components/layout/Footer.astro';
import { getBrand } from '@shared/lib/brand';

const brand = await getBrand('eqology');
---
<BrandLayout brand={brand} title="Footer Preview">
  <main style="padding:60px 28px; max-width:920px; margin:0 auto;">
    <p style="font-size:14px; color:#7a8983; font-family:ui-monospace,monospace;">__preview/footer.html · brand: eqology</p>
    <h1 style="font-family:'Fraunces',serif;font-weight:400;font-size:32px;color:#0f1b17;margin:8px 0 16px;">Footer isoliert</h1>
    <p style="color:#4a5c53;line-height:1.6;">Diese Seite zeigt nur den Footer (site-footer mit voller Nav). Inhalt oben ist Platzhalter.</p>
    <p style="margin-top:30px;"><a href="/dev.html" style="color:var(--brand);">← zurück zum Dev-Index</a></p>
  </main>
  <Footer brand={brand} />
</BrandLayout>
