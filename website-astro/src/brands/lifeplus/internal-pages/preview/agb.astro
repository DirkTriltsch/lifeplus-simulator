---
import BrandLayout from '@shared/components/layout/BrandLayout.astro';
import PreviewBanner from '@shared/components/preview/PreviewBanner.astro';
import LegalAgbDefault from '@shared/components/sections/LegalAgbDefault.astro';
import { getBrand } from '@shared/lib/brand';
import { contact } from '@shared/lib/contact';

const brand = await getBrand('lifeplus');
---
<BrandLayout brand={brand} title="Preview: AGB">
  <PreviewBanner brandId="lifeplus" component="LegalAgbDefault.astro" livePage="/agb.html" />
  <main class="legal-page"><div class="container">
    <LegalAgbDefault brand={brand} contact={contact} source="shared/components/sections/LegalAgbDefault.astro" />
  </div></main>
  <style is:global>
    .legal-page { padding: 3rem 0 4rem; max-width: 720px; margin: 0 auto; padding-left: 28px; padding-right: 28px; }
    .legal-page h1 { font-size: 1.75rem; margin: 0 0 0.5rem; color: #0f172a; }
    .legal-page h2 { font-size: 1.15rem; margin: 2rem 0 0.6rem; color: #0f172a; }
    .legal-page h3 { font-size: 1rem; margin: 1.5rem 0 0.4rem; color: #1e293b; }
    .legal-page p, .legal-page address, .legal-page li { font-size: 0.95rem; color: #334155; line-height: 1.6; margin: 0 0 0.85rem; }
    .legal-page .legal-meta-top { font-size: 0.85rem; color: #94a3b8; margin-bottom: 2rem; }
    .legal-page .legal-meta { font-size: 0.8rem; color: #94a3b8; margin-top: 2rem; }
  </style>
</BrandLayout>
