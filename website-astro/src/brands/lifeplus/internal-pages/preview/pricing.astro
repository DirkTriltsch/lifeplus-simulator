---
import BrandLayout from '@shared/components/layout/BrandLayout.astro';
import PreviewBanner from '@shared/components/preview/PreviewBanner.astro';
import PricingPageDefault from '@shared/components/sections/PricingPageDefault.astro';
import { getBrand } from '@shared/lib/brand';
import { getPage } from '@shared/lib/pageContent';

const brand = await getBrand('lifeplus');
const pricing = await getPage('lifeplus', 'pricing');
---
<BrandLayout brand={brand} title="Preview: Pricing" paddle>
  <PreviewBanner brandId="lifeplus" component="PricingPageDefault.astro" livePage="/pricing.html" />
  <PricingPageDefault brand={brand} pricing={pricing} source="shared/components/sections/PricingPageDefault.astro" />
</BrandLayout>
