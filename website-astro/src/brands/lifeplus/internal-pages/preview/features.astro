---
import BrandLayout from '@shared/components/layout/BrandLayout.astro';
import PreviewBanner from '@shared/components/preview/PreviewBanner.astro';
import FeaturesPageDefault from '@shared/components/sections/FeaturesPageDefault.astro';
import { getBrand } from '@shared/lib/brand';

const brand = await getBrand('lifeplus');
---
<BrandLayout brand={brand} title="Preview: Features">
  <PreviewBanner brandId="lifeplus" component="FeaturesPageDefault.astro" livePage="/features.html" />
  <FeaturesPageDefault brand={brand} source="shared/components/sections/FeaturesPageDefault.astro" />
</BrandLayout>
