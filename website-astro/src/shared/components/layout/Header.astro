---
import type { Brand } from '@shared/content-schemas/config';

interface Props {
  brand: Brand;
  active?: 'home' | 'features' | 'pricing' | 'faq' | 'account';
}
const { brand, active } = Astro.props;
const { lockup } = brand;
const cls = (k: Props['active']) => (active === k ? 'active' : undefined);
const isHome = active === 'home';
const conceptHref = isHome ? '#kernbotschaft' : 'index.html#kernbotschaft';
const faqHref = isHome ? '#faq' : 'index.html#faq';
---
<header class="site-header site-header--dark" data-section="Header.astro" data-source={`brands/${brand.id}/brand.yaml`}>
  <div class="container">
    <a class="lockup lockup--header" href="index.html" aria-label={brand.siteName}>
      <span class="lockup-mark">
        <svg viewBox="0 0 256 256" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
          <rect width="256" height="256" rx="28" fill={lockup.markFill} />
          <text
            x="29.16"
            y="158.067"
            fill="#FFFFFF"
            font-family="Inter, system-ui, -apple-system, sans-serif"
            font-weight="600"
            letter-spacing="-3"
            style="white-space:pre; font-size:145.9px;"
            transform="matrix(1.268075, 0, 0, 1.045683, -16.903988, -22.842188)"
          >{lockup.initial}</text>
          <path
            d="M 26.39 182.443 L 86.155 180.164 L 127.99 173.328 C 151.895 167.249 171.818 153.575 187.756 132.306 C 203.692 111.034 217.637 89.764 229.59 68.494"
            fill="none"
            stroke="#FFFFFF"
            stroke-width="15.36"
            stroke-linecap="round"
            stroke-linejoin="round"
          />
          <path
            d="M 22.943 210.906 C 45.668 204.506 68.394 204.506 91.118 210.906 C 113.842 217.307 136.567 217.307 159.293 210.906 C 182.016 204.506 206.807 204.506 233.664 210.906"
            fill="none"
            stroke={lockup.waveColor}
            stroke-width="8.96"
            stroke-linecap="round"
            opacity="0.7"
          />
        </svg>
      </span>
      <span class="lockup-text">
        <span class="lockup-name"
          ><span class="lockup-neutral">{lockup.wordNeutral}</span
          ><span class="lockup-accent">{lockup.wordAccent}</span></span
        >
        <span class="lockup-sub">{lockup.taglineDe}</span>
      </span>
    </a>
    <nav class="site-nav-links">
      <a href={conceptHref} class={cls('home')}>Konzept</a>
      <a href="features.html" class={cls('features')}>Funktionen</a>
      <a href="pricing.html" class={cls('pricing')}>Preise</a>
      <a href={faqHref} class={cls('faq')}>FAQ</a>
      <a href="mein-konto.html" class={`js-account-link ${cls('account') ?? ''}`.trim()}>Mein Konto</a>
    </nav>
    <a class="nav-cta nav-cta--dark" href={brand.appUrl}>
      Simulator starten
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" width="14" height="14"
        ><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" /></svg
      >
    </a>
  </div>
</header>
