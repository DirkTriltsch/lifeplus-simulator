---
import type { FeatureTeaser } from '@shared/content-schemas/config';
interface Props extends FeatureTeaser { source?: string; }
const { headline, items, source } = Astro.props;
---
<section class="features" data-section="FeatureTeaserDefault.astro" data-source={source}>
  <div class="wrap">
    <h2>{headline}</h2>
    <ul>
      {items.map((item) => (
        <li>
          <h3>{item.title}</h3>
          <p>{item.body}</p>
        </li>
      ))}
    </ul>
  </div>
</section>

<style>
  .features { padding: var(--space-6) var(--space-3); background: #fafafa; }
  .wrap { max-width: var(--max-content); margin: 0 auto; }
  h2 { font-size: clamp(1.5rem, 3vw, 2.2rem); text-align: center; margin-bottom: var(--space-4); }
  ul {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: var(--space-3);
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
  }
  li { background: #fff; padding: var(--space-3); border-radius: var(--radius-md); border: 1px solid #eee; }
  h3 { color: var(--brand); font-size: 1.15rem; }
  p { color: #555; margin: 0; }
</style>
