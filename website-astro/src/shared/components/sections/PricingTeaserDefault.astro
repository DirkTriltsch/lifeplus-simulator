---
import type { PricingTeaser } from '@shared/content-schemas/config';
interface Props extends PricingTeaser { source?: string; }
const { headline, body, ctaLabel, ctaUrl = '/pricing', source } = Astro.props;
---
<section class="pricing-teaser" data-section="PricingTeaserDefault.astro" data-source={source}>
  <div class="wrap">
    <h2>{headline}</h2>
    <p>{body}</p>
    <a href={ctaUrl} class="cta">{ctaLabel}</a>
  </div>
</section>

<style>
  .pricing-teaser { padding: var(--space-6) var(--space-3); text-align: center; }
  .wrap { max-width: 42rem; margin: 0 auto; }
  h2 { color: var(--brand); }
  p { color: #444; font-size: 1.1rem; }
  .cta {
    display: inline-block;
    margin-top: var(--space-2);
    padding: .9rem 1.7rem;
    background: var(--cta);
    color: #fff;
    text-decoration: none;
    border-radius: var(--radius-md);
    font-weight: 600;
  }
  .cta:hover { background: var(--cta-dark); }
</style>
