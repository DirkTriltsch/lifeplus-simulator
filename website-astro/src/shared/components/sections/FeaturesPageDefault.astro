<style is:global>
  /* Features-Page-Styles — 1:1 uebernommen aus website/templates/features.html */
  .wrap { max-width: 1240px; margin: 0 auto; padding: 0 28px; }
  @media (max-width: 720px) { .wrap { padding: 0 20px; } }

  :root {
    --serif: 'Fraunces', 'Source Serif 4', Georgia, serif;
    --sans: 'Inter', system-ui, -apple-system, sans-serif;
    --mono: 'JetBrains Mono', 'SF Mono', Menlo, monospace;
    --ink: #0F1B17;
    --ink-2: #2C4138;
    --ink-3: #4A5C53;
    --ink-4: #7A8983;
    --ink-5: #A8B2AD;
    --line: #E1E5E2;
    --line-soft: #EEF1EF;
    --paper: #FAFBF9;
    --paper-2: #F4F6F2;
  }

  body { font-family: var(--sans); color: var(--ink); background: var(--paper); line-height: 1.55; font-size: 16px; }
  .btn-primary::after { content: none; }

  .ph { padding: 84px 0 56px; text-align: center; background: radial-gradient(ellipse 700px 300px at 50% 0%, var(--brand-surface) 0%, transparent 70%); }
  .ph-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--brand); margin-bottom: 22px; font-weight: 500; }
  .ph-eyebrow::before, .ph-eyebrow::after { content: ""; width: 24px; height: 1px; background: var(--brand); }
  .ph-h1 { font-family: var(--serif); font-size: clamp(38px, 5.2vw, 60px); line-height: 1.05; letter-spacing: -0.025em; font-weight: 400; color: var(--ink); margin: 0 0 18px; }
  .ph-h1 em { font-style: italic; color: var(--brand); }
  .ph-sub { font-size: 18px; color: var(--ink-3); max-width: 620px; margin: 0 auto; line-height: 1.6; }

  .sec-eyebrow { display: inline-flex; align-items: center; gap: 8px; font-family: var(--mono); font-size: 11px; text-transform: uppercase; letter-spacing: 0.16em; color: var(--brand); margin-bottom: 20px; font-weight: 500; }
  .sec-eyebrow::before { content: ""; width: 24px; height: 1px; background: var(--brand); }
  .sec-h { font-family: var(--serif); font-size: clamp(28px, 3.4vw, 38px); line-height: 1.1; letter-spacing: -0.02em; font-weight: 400; color: var(--ink); margin: 0 0 16px; max-width: 760px; }
  .sec-h em { font-style: italic; color: var(--brand); }

  .feature { padding: 88px 0; border-bottom: 0.5px solid var(--line); }
  @media (max-width: 720px) { .feature { padding: 56px 0; } }
  .feature-row { display: grid; grid-template-columns: 1fr 1.15fr; gap: 72px; align-items: center; }
  .feature-row.reverse { grid-template-columns: 1.15fr 1fr; }
  .feature-row.reverse .feature-text { order: 2; }
  .feature-row.reverse .feature-visual { order: 1; }
  @media (max-width: 900px) {
    .feature-row, .feature-row.reverse { grid-template-columns: 1fr; gap: 36px; }
    .feature-row.reverse .feature-text { order: 1; }
    .feature-row.reverse .feature-visual { order: 2; }
  }
  .feature-num { font-family: var(--mono); font-size: 11px; letter-spacing: 0.16em; color: var(--brand); margin-bottom: 14px; font-weight: 500; }
  .feature-h { font-family: var(--serif); font-size: clamp(26px, 3.2vw, 36px); font-weight: 400; line-height: 1.1; letter-spacing: -0.02em; margin: 0 0 16px; color: var(--ink); }
  .feature-h em { font-style: italic; color: var(--brand); }
  .feature-p { font-size: 16px; color: var(--ink-3); line-height: 1.65; margin: 0 0 20px; }
  .feature-p-highlight { background: var(--brand-surface); border-left: 3px solid var(--brand); padding: 14px 18px; border-radius: 0 8px 8px 0; color: var(--ink-2); font-size: 15.5px; }
  .feature-p-highlight b { color: var(--ink); font-weight: 600; }
  .feature-list { list-style: none; padding: 0; margin: 0; }
  .feature-list li { padding: 14px 0; border-top: 0.5px solid var(--line-soft); display: flex; gap: 14px; font-size: 15px; color: var(--ink-2); }
  .feature-list li:last-child { border-bottom: 0.5px solid var(--line-soft); }
  .feature-list .marker { width: 24px; height: 24px; flex-shrink: 0; border-radius: 6px; background: var(--brand-surface); display: flex; align-items: center; justify-content: center; color: var(--brand); }
  .feature-list .marker svg { width: 12px; height: 12px; }
  .feature-list b { color: var(--ink); font-weight: 500; }

  .visual-frame { background: #fff; border: 0.5px solid var(--line); border-radius: 16px; padding: 18px; box-shadow: 0 1px 2px rgba(15,27,23,0.03), 0 8px 20px rgba(15,27,23,0.05); }
  .visual-bar { display: flex; align-items: center; gap: 10px; padding-bottom: 14px; margin-bottom: 16px; border-bottom: 0.5px solid var(--line-soft); }
  .visual-bar .dots span { display: inline-block; width: 8px; height: 8px; border-radius: 50%; background: var(--line); margin-right: 5px; }
  .visual-bar .file { font-family: var(--mono); font-size: 10px; color: var(--ink-4); letter-spacing: 0.04em; }

  .v-sliders { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  .v-slider { padding: 14px; background: var(--paper-2); border-radius: 10px; }
  .v-slider-head { display: flex; justify-content: space-between; align-items: baseline; margin-bottom: 10px; }
  .v-slider-label { font-size: 11px; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.08em; font-weight: 500; }
  .v-slider-val { font-family: var(--serif); font-size: 18px; font-weight: 400; color: var(--ink); letter-spacing: -0.02em; }
  .v-slider-val sup { font-size: 11px; color: var(--ink-4); margin-left: 2px; }
  .v-slider-track { height: 4px; background: var(--line); border-radius: 100px; position: relative; }
  .v-slider-fill { position: absolute; left: 0; top: 0; height: 100%; background: var(--brand); border-radius: 100px; }
  .v-slider-thumb { position: absolute; top: 50%; width: 14px; height: 14px; background: #fff; border: 2px solid var(--brand); border-radius: 50%; transform: translate(-50%, -50%); box-shadow: 0 1px 4px color-mix(in srgb, var(--brand) 25%, transparent); }
  .v-slider-scale { display: flex; justify-content: space-between; margin-top: 6px; font-family: var(--mono); font-size: 9px; color: var(--ink-5); }

  .v-chart-head { display: flex; justify-content: space-between; align-items: flex-end; margin-bottom: 14px; }
  .v-chart-h-label { font-size: 11px; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 500; margin-bottom: 6px; }
  .v-chart-h-num { font-family: var(--serif); font-size: 38px; font-weight: 400; color: var(--ink); letter-spacing: -0.025em; line-height: 1; }
  .v-chart-h-num .cur { color: var(--ink-3); font-weight: 300; font-size: 24px; }
  .v-chart-tabs { display: flex; gap: 4px; background: var(--paper-2); padding: 3px; border-radius: 100px; }
  .v-chart-tab { padding: 5px 12px; font-size: 11px; color: var(--ink-4); border-radius: 100px; font-weight: 500; }
  .v-chart-tab.active { background: #fff; color: var(--brand); box-shadow: 0 1px 2px rgba(0,0,0,0.06); }
  .v-chart-body { height: 220px; position: relative; }
  .v-chart-body svg { width: 100%; height: 100%; overflow: visible; }
  .v-chart-tooltip { position: absolute; background: var(--lockup-dark-bg); color: #fff; padding: 10px 12px; border-radius: 8px; font-size: 11px; box-shadow: 0 6px 20px rgba(0,0,0,0.18); pointer-events: none; }
  .v-chart-tooltip .label { font-family: var(--mono); color: var(--brand-soft); margin-bottom: 3px; letter-spacing: 0.05em; font-size: 9px; text-transform: uppercase; }
  .v-chart-tooltip .val { font-family: var(--serif); font-size: 18px; font-weight: 400; letter-spacing: -0.01em; }

  .v-kpi-row { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; margin-bottom: 14px; }
  .v-kpi { background: var(--paper-2); padding: 14px; border-radius: 10px; }
  .v-kpi-label { font-size: 10px; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.1em; margin-bottom: 6px; font-weight: 500; }
  .v-kpi-val { font-family: var(--serif); font-size: 22px; color: var(--ink); letter-spacing: -0.02em; line-height: 1; margin-bottom: 4px; }
  .v-kpi-delta { font-family: var(--mono); font-size: 10px; color: var(--brand); letter-spacing: 0.04em; }
  .v-rank { background: var(--paper-2); padding: 16px; border-radius: 10px; }
  .v-rank-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 14px; }
  .v-rank-title { font-size: 11px; color: var(--ink-4); text-transform: uppercase; letter-spacing: 0.1em; font-weight: 500; }
  .v-rank-row { display: grid; grid-template-columns: 10px 80px 1fr auto; gap: 12px; align-items: center; padding: 10px 0; border-top: 0.5px solid var(--line); font-size: 13px; }
  .v-rank-row:first-of-type { border-top: none; }
  .v-rank-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--line); }
  .v-rank-row.achieved .v-rank-dot { background: var(--brand); box-shadow: 0 0 0 3px color-mix(in srgb, var(--brand) 12%, transparent); }
  .v-rank-name { color: var(--ink-2); font-weight: 500; font-size: 13px; }
  .v-rank-row.achieved .v-rank-name { color: var(--brand); font-weight: 600; }
  .v-rank-meta { font-family: var(--mono); font-size: 10px; color: var(--ink-4); }
