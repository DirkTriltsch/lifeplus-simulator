---
import type { TrustStrip } from '@shared/content-schemas/config';
interface Props extends TrustStrip { source?: string; }
const { headline, items, source } = Astro.props;
---
<section class="trust" data-section="TrustStripDefault.astro" data-source={source}>
  <div class="wrap">
    {headline && <p class="headline">{headline}</p>}
    <ul>
      {items.map((item) => <li>{item}</li>)}
    </ul>
  </div>
</section>

<style>
  .trust { padding: var(--space-3) var(--space-3); background: #f7f7f7; border-bottom: 1px solid #eee; }
  .wrap { max-width: var(--max-content); margin: 0 auto; text-align: center; }
  .headline { font-size: .9rem; color: #666; text-transform: uppercase; letter-spacing: .08em; margin-bottom: .75rem; }
  ul { list-style: none; padding: 0; margin: 0; display: flex; flex-wrap: wrap; gap: var(--space-3); justify-content: center; }
  li { color: #333; font-weight: 500; }
  li::before { content: "✓ "; color: var(--brand); font-weight: 700; }
</style>
