---
import type { Brand } from '@shared/content-schemas/config';

interface Props { brand: Brand; source?: string; }
const { brand, source } = Astro.props;
const ac = brand.accentColor;
---
<!-- ===== Hero ===== -->
<section class="hero" data-section="IndexPageDefault.astro" data-source={source}>
  <div class="wrap hero-inner">
    <div class="hero-grid">
      <div>
        <div class="hero-eyebrow">
          <span class="dot"></span>
          Für {brand.productName}-Sponsoren
          <span class="tag"><span class="tag-neutral">{brand.lockup.wordNeutral}</span><span class="tag-accent">{brand.lockup.wordAccent}</span></span>
        </div>

        <h1 class="hero-h1">
          Netzwerk-Wachstum versteht man nicht in <em>Tabellen</em>.
          <span class="hero-h1-sub">Man versteht es, wenn man es verändert.</span>
        </h1>

        <p class="hero-sub">
          Mit fünf Basiswerten simulierst du live, wie Member, Shopper, Umsatz, Duplikation und Fluktuation über Jahre auf <strong>Vergütung, Ziele und Teamstruktur</strong> wirken. Für ruhigere Gespräche mit Interessenten und mehr Orientierung in deiner Downline.
        </p>

        <div class="hero-ctas">
          <a href={brand.appUrl} class="btn-primary">
            Simulator starten
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>

        <div class="hero-proof">
          <div class="hero-proof-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Mobil &amp; Desktop
          </div>
          <div class="hero-proof-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Abo · als Betriebsausgabe absetzbar
          </div>
          <div class="hero-proof-item">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Sofort einsatzbereit
          </div>
        </div>
      </div>

      <div class="hero-illu">
        <div class="product-frame">
          <div class="pf-toolbar">
            <div class="pf-dots"><span></span><span></span><span></span></div>
            <div class="pf-title">{brand.siteDomain}</div>
            <div class="pf-badge">LIVE</div>
          </div>

          <div class="pf-hero-num-label">Provision · Jahr 10 · pro Monat</div>
          <div class="pf-hero-num">
            <span class="currency">€</span>8.420<span class="unit">/Mon</span>
          </div>
          <div class="pf-hero-delta">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="22 7 13.5 15.5 8.5 10.5 2 17" stroke-linecap="round" stroke-linejoin="round"/><polyline points="16 7 22 7 22 13" stroke-linecap="round" stroke-linejoin="round"/></svg>
            Realistisch · 30% Dup · 20% Fluk
          </div>

          <div class="pf-chart">
            <svg viewBox="0 0 480 120" preserveAspectRatio="none">
              <defs>
                <linearGradient id="pf-area" x1="0" x2="0" y1="0" y2="1">
                  <stop offset="0%" stop-color={ac} stop-opacity="0.2"/>
                  <stop offset="100%" stop-color={ac} stop-opacity="0"/>
                </linearGradient>
              </defs>
              <line x1="0" y1="30" x2="480" y2="30" stroke="#EEF1EF" stroke-width="0.5" stroke-dasharray="2 3"/>
              <line x1="0" y1="60" x2="480" y2="60" stroke="#EEF1EF" stroke-width="0.5" stroke-dasharray="2 3"/>
              <line x1="0" y1="90" x2="480" y2="90" stroke="#EEF1EF" stroke-width="0.5" stroke-dasharray="2 3"/>
              <path d="M 24 108 L 74 104 L 124 96 L 174 84 L 224 70 L 274 55 L 324 42 L 374 30 L 424 20 L 456 14 L 456 120 L 24 120 Z" fill="url(#pf-area)" opacity="0.85"/>
              <path d="M 24 108 L 74 104 L 124 96 L 174 84 L 224 70 L 274 55 L 324 42 L 374 30 L 424 20 L 456 14" fill="none" stroke={ac} stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="74" cy="104" r="2.5" fill={ac}/><circle cx="124" cy="96" r="2.5" fill={ac}/><circle cx="174" cy="84" r="2.5" fill={ac}/><circle cx="224" cy="70" r="2.5" fill={ac}/><circle cx="274" cy="55" r="2.5" fill={ac}/><circle cx="324" cy="42" r="2.5" fill={ac}/><circle cx="374" cy="30" r="2.5" fill={ac}/><circle cx="424" cy="20" r="2.5" fill={ac}/>
              <circle cx="456" cy="14" r="6" fill={ac} stroke="white" stroke-width="3"/>
              <text x="24" y="118" font-family="JetBrains Mono" font-size="9" fill="#7A8983">J1</text>
              <text x="170" y="118" font-family="JetBrains Mono" font-size="9" fill="#7A8983">J4</text>
              <text x="316" y="118" font-family="JetBrains Mono" font-size="9" fill="#7A8983">J7</text>
              <text x="442" y="118" font-family="JetBrains Mono" font-size="9" fill="#7A8983">J10</text>
            </svg>
          </div>

          <div class="pf-sliders">
            <div class="pf-slider-tile">
              <div class="pf-slider-label">Member/J</div>
              <div class="pf-slider-value">2</div>
              <div class="pf-slider-bar" style="--w:25%"></div>
            </div>
            <div class="pf-slider-tile">
              <div class="pf-slider-label">Shopper/J</div>
              <div class="pf-slider-value">3</div>
              <div class="pf-slider-bar" style="--w:38%"></div>
            </div>
            <div class="pf-slider-tile">
              <div class="pf-slider-label">IP/Monat</div>
              <div class="pf-slider-value">200</div>
              <div class="pf-slider-bar" style="--w:60%"></div>
            </div>
          </div>

          <div class="pf-annotation a1">Hero-Zahl · live</div>
          <div class="pf-annotation a2">5 Slider</div>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== Trust strip ===== -->
<section class="trust-strip">
  <div class="wrap trust-inner">
    <div class="trust-label">Eingebaute Logik</div>
    <div class="trust-items">
      <div class="trust-item"><span class="trust-num">5</span><span class="trust-cap">Slider</span></div>
      <div class="trust-item"><span class="trust-num">10</span><span class="trust-cap">Jahre Verlauf</span></div>
      <div class="trust-item"><span class="trust-num">3</span><span class="trust-cap">Phasen-Vergütung</span></div>
      <div class="trust-item"><span class="trust-num trust-num-text">Believer <span class="trust-arrow">→</span> 3* Diamond</span><span class="trust-cap">alle Stufen abgedeckt</span></div>
      <div class="trust-item"><span class="trust-num">&lt;100ms</span><span class="trust-cap">Reaktion</span></div>
    </div>
  </div>
</section>

<!-- ===== Core Message ===== -->
<section class="core" id="kernbotschaft">
  <div class="wrap core-inner">
    <div class="core-grid-intro">
      <div>
        <div class="core-eyebrow">DAS PROBLEM</div>
        <h2 class="core-h">
          Der Vergütungsplan ist transparent —<br>
          <em>Wachstum im Netzwerk ist es nicht.</em>
        </h2>
        <p class="core-sub">
          {brand.siteName} ändert das. Eine Live-Simulation mit wenigen Parametern, die den Vergütungsplan visualisiert — und zwar genau dort, wo Menschen aussteigen: bei der mentalen Vorstellung, wie ein Netzwerk über 10 Jahre wächst.
        </p>
      </div>

      <div>
        <div class="core-viz-frame">
          <svg viewBox="0 0 360 200" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
            <defs>
              <linearGradient id="core-area" x1="0" x2="0" y1="0" y2="1">
                <stop offset="0%" stop-color="#9FBA37" stop-opacity="0.3"/>
                <stop offset="100%" stop-color="#9FBA37" stop-opacity="0"/>
              </linearGradient>
            </defs>
            <line x1="0" y1="170" x2="360" y2="170" stroke="rgba(255,255,255,0.2)" stroke-width="0.5"/>
            <text x="60" y="30" fill="rgba(255,255,255,0.65)" font-family="JetBrains Mono" font-size="10" letter-spacing="0.5">FLACH</text>
            <line x1="5" y1="35" x2="55" y2="35" stroke="rgba(255,255,255,0.35)" stroke-width="0.5" stroke-dasharray="2 2"/>
            <line x1="120" y1="35" x2="220" y2="35" stroke="rgba(255,255,255,0.35)" stroke-width="0.5" stroke-dasharray="2 2"/>
            <text x="265" y="30" fill="#9FBA37" font-family="JetBrains Mono" font-size="10" letter-spacing="0.5">HOCKEYSTICK</text>
            <line x1="240" y1="35" x2="260" y2="35" stroke="#9FBA37" stroke-width="0.5" stroke-dasharray="2 2"/>
            <line x1="320" y1="35" x2="355" y2="35" stroke="#9FBA37" stroke-width="0.5" stroke-dasharray="2 2"/>
            <path d="M 20 168 L 56 167 L 92 165 L 128 162 L 164 156 L 200 145 L 236 124 L 272 92 L 308 56 L 344 22 L 344 200 L 20 200 Z" fill="url(#core-area)"/>
            <path d="M 20 168 L 56 167 L 92 165 L 128 162 L 164 156 L 200 145 L 236 124 L 272 92 L 308 56 L 344 22" fill="none" stroke="#9FBA37" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round"/>
            <text x="20" y="190" fill="rgba(255,255,255,0.5)" font-family="JetBrains Mono" font-size="9" text-anchor="middle">J1</text>
            <text x="92" y="190" fill="rgba(255,255,255,0.5)" font-family="JetBrains Mono" font-size="9" text-anchor="middle">J3</text>
            <text x="164" y="190" fill="rgba(255,255,255,0.5)" font-family="JetBrains Mono" font-size="9" text-anchor="middle">J5</text>
            <text x="236" y="190" fill="rgba(255,255,255,0.5)" font-family="JetBrains Mono" font-size="9" text-anchor="middle">J7</text>
            <text x="308" y="190" fill="rgba(255,255,255,0.5)" font-family="JetBrains Mono" font-size="9" text-anchor="middle">J9</text>
            <line x1="200" y1="42" x2="200" y2="180" stroke="#9FBA37" stroke-width="0.5" stroke-dasharray="3 3" opacity="0.4"/>
            <text x="200" y="50" fill="#9FBA37" font-family="Inter" font-size="9" text-anchor="middle" font-style="italic">Wendepunkt</text>
            <circle cx="344" cy="22" r="5" fill="#9FBA37" stroke="white" stroke-width="2"/>
          </svg>
          <div class="core-viz-cap">Genau dieses Bild sieht dein Interessent — in seiner Hand, mit seinen Werten.</div>
        </div>
      </div>
    </div>

    <div class="core-divider"></div>

    <div class="core-paths-head">
      <div class="core-eyebrow">ZWEI SITUATIONEN · EIN WERKZEUG</div>
      <h3 class="core-paths-h">Im Interessentengespräch und in der <em>eigenen Downline.</em></h3>
    </div>

    <div class="core-grid" style="grid-template-columns: repeat(2, 1fr); max-width: 960px; margin: 0 auto;">
      <div class="core-card">
        <div class="core-card-num">01 — Im Interessentengespräch</div>
        <h3 class="core-card-h">Aus Vortrag wird gemeinsames Rechnen.</h3>
        <p class="core-card-p">Statt den kompletten Vergütungsplan zu erklären, fragt der Sponsor: „Wie viele neue Member traust du dir pro Jahr zu? Wie viele Shopper? Welche Duplikation?" Der Interessent bewegt die Slider selbst — und sieht, was aus seinen eigenen Annahmen entsteht. Kein Vortrag, ein Gespräch.</p>
      </div>
      <div class="core-card">
        <div class="core-card-num">02 — In der eigenen Downline</div>
        <h3 class="core-card-h">Durststrecken einordnen, statt sie wegreden.</h3>
        <p class="core-card-p">Partner zweifeln nicht am Werkzeug — sie zweifeln am Tempo. Der Simulator zeigt, warum Jahr 1 oft klein aussieht, welche Zwischenziele trotzdem realistisch sind und was 12, 24 oder 36 Monate Kontinuität bewirken. Transparenz statt Hype.</p>
      </div>
    </div>
  </div>
</section>

<!-- ===== Feature Teaser ===== -->
<section class="feat-teaser" id="funktionen">
  <div class="wrap">
    <div class="feat-teaser-head">
      <div class="sec-eyebrow">Funktionen im Überblick</div>
      <h2 class="sec-h">Drei Bausteine. <em>Ein Gespräch.</em></h2>
      <p class="sec-sub">Slider, Verlauf und Ziele-Leiter greifen ineinander — Simulationsmodelle und Netzwerk-Visualisierungen ergänzen das Bild. Details auf der Funktionsseite.</p>
    </div>
    <div class="feat-cards">
      <a href="/features.html#slider" class="feat-card">
        <div class="feat-card-num">01 / SLIDER</div>
        <h3 class="feat-card-h">Fünf Regler, kein Vergütungsplan-Vortrag</h3>
        <p class="feat-card-p">Member, Shopper, IP, Duplikation, Fluktuation — er stellt selbst ein, was er sich zutraut. Jede Bewegung ist eine Frage.</p>
        <span class="feat-card-arrow">
          Funktion ansehen
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>
      <a href="/features.html#chart" class="feat-card">
        <div class="feat-card-num">02 / VERLAUF</div>
        <h3 class="feat-card-h">10 Jahre auf einer Kurve</h3>
        <p class="feat-card-p">Der Sprung von Jahr 3 zu Jahr 7 wird sichtbar — als Bild, nicht als Tabelle. Monats- oder Jahresansicht in einem Tap.</p>
        <span class="feat-card-arrow">
          Funktion ansehen
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>
      <a href="/features.html#ziele" class="feat-card">
        <div class="feat-card-num">03 / ZIELE-LEITER</div>
        <h3 class="feat-card-h">Zwischenziele statt Endsumme</h3>
        <p class="feat-card-p">Produktkosten refinanziert, Auto finanziert, mietfrei wohnen, vollwertiges Einkommen — eigene Wegmarken im Jahresverlauf machen Fortschritt greifbar.</p>
        <span class="feat-card-arrow">
          Funktion ansehen
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
      </a>
    </div>
    <div class="feat-teaser-cta">
      <a href="/features.html" class="btn-secondary">
        Alle Funktionen ansehen
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
    </div>
  </div>
</section>

<!-- ===== Pricing Teaser ===== -->
<section class="pricing-teaser" id="pricing">
  <div class="wrap">
    <div class="pricing-grid">
      <div class="pricing-intro">
        <div class="sec-eyebrow">Preise</div>
        <h2 class="sec-h">Faires Werkzeug, <em>fairer Preis.</em></h2>
        <p class="sec-sub">
          {brand.siteName} ist ein Abo-Werkzeug für Sponsoren. Monatlich kündbar — oder im Jahresabo mit spürbarem Rabatt. Beide Pläne sind als <strong>Betriebsausgabe absetzbar.</strong>
        </p>
        <a href="/pricing.html" class="btn-secondary">
          Alle Preise &amp; Details ansehen
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>

      <div class="pricing-cards">
        <div class="pricing-card">
          <div class="pc-tag">Flexibel</div>
          <div class="pc-name">Monatlich</div>
          <div class="pc-price">
            <span class="pc-price-cur">€</span><span class="pc-price-val">19</span><span class="pc-price-unit">/Monat</span>
          </div>
          <div class="pc-bill">€19 monatlich abgerechnet</div>
          <ul class="pc-features">
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/></svg>Voller Funktionsumfang</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/></svg>Mobil, Tablet &amp; Desktop</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/></svg>Monatlich kündbar</li>
          </ul>
        </div>

        <div class="pricing-card pc-featured">
          <div class="pc-tag pc-tag-highlight">2 Monate gespart</div>
          <div class="pc-name">Jährlich</div>
          <div class="pc-price">
            <span class="pc-price-cur">€</span><span class="pc-price-val">15</span><span class="pc-price-unit">/Monat</span>
          </div>
          <div class="pc-bill">€180 jährlich · Ersparnis €48</div>
          <ul class="pc-features">
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/></svg>Alles aus Monatlich</li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/></svg><span><strong>~21 % günstiger</strong> als Monatsabo</span></li>
            <li><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round"/></svg>Eine Rechnung pro Jahr</li>
          </ul>
        </div>
      </div>
    </div>

    <div class="pricing-note">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="9"/><path d="M12 8v4M12 16h.01" stroke-linecap="round"/></svg>
      <span>Alle Preise inkl. MwSt. Als Sponsor setzt du das Abo als <strong>Betriebsausgabe</strong> ab — sprich im Zweifel mit deinem Steuerberater.</span>
    </div>
  </div>
</section>

<!-- ===== FAQ ===== -->
<section class="faq" id="faq">
  <div class="wrap faq-grid">
    <div>
      <div class="sec-eyebrow">FAQ</div>
      <h2 class="sec-h">Was Sponsoren <em>am häufigsten</em> fragen.</h2>
      <p class="sec-sub">Wenn deine Frage fehlt — kurze Mail an den Support, dann landet sie hier. Und wird beantwortet.</p>
    </div>
    <div class="faq-list">
      <div class="faq-item open">
        <button class="faq-q" type="button">
          <span>Sind die Zahlen wirklich realistisch — oder Marketing?</span>
          <span class="faq-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg></span>
        </button>
        <div class="faq-a">
          <div class="faq-a-inner">
            <p>Realistisch heißt: realistisch für die Eingabewerte. Setzt du 100 % Duplikation und 0 % Fluktuation, kommt eine Milliarden-Zahl raus — und die ist mathematisch korrekt, aber praktisch unmöglich. Setzt du 30 % Duplikation und 20 % Fluktuation, landest du bei den ehrlichen €4.000–€10.000/Monat, die ein engagierter Sponsor nach 10 Jahren realistisch erreicht.</p>
            <p>Der Simulator lügt nicht. Er rechnet exakt das, was du eingibst.</p>
          </div>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button">
          <span>Welche Vergütungen sind eingerechnet?</span>
          <span class="faq-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg></span>
        </button>
        <div class="faq-a">
          <div class="faq-a-inner">
            <p>Alle drei Phasen des Vergütungsplans sind in der Engine abgebildet — <b>Phase 1</b> mit der Ebenen-Vergütung (40 % auf Ebenen 1–3, inkl. Empfehlung, Shop-Rabatt und Shop), <b>Phase 2</b> Leadership (12 % ab Ebene 4), und <b>Phase 3</b> Leadership Development (8 % ab Ebene 4). Komprimierung wird korrekt berücksichtigt.</p>
          </div>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button">
          <span>Kann ich das im Kundengespräch zeigen — oder ist das zu komplex?</span>
          <span class="faq-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg></span>
        </button>
        <div class="faq-a">
          <div class="faq-a-inner">
            <p>Genau dafür ist es gebaut. Fünf Slider sind in 30 Sekunden erklärt. Wer nur die Ergebniszahl zeigen will, kann die Komplexität bewusst ausblenden — sie kommt erst, wenn der Interessent oder Partner sie sehen will.</p>
          </div>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button">
          <span>Wie werden die Stufen-Jahre berechnet?</span>
          <span class="faq-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg></span>
        </button>
        <div class="faq-a">
          <div class="faq-a-inner">
            <p>Pro Jahr prüft die Engine die drei Stufen-Voraussetzungen des Plans: <b>AV</b> (Aktivitätsvolumen), <b>QGV</b> (Qualifiziertes Gruppenvolumen) und Anzahl der <b>QL</b> (Qualifizierte Beine). Sobald ein Jahr die Bedingungen einer Stufe — von Believer bis Diamond — erfüllt, wird sie als „erreicht in Jahr X" markiert.</p>
          </div>
        </div>
      </div>
      <div class="faq-item">
        <button class="faq-q" type="button">
          <span>Was kostet {brand.siteName}?</span>
          <span class="faq-icon"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 5v14M5 12h14" stroke-linecap="round"/></svg></span>
        </button>
        <div class="faq-a">
          <div class="faq-a-inner">
            <p>Zwei Optionen: <strong>€19/Monat</strong> bei monatlicher Abrechnung, oder <strong>€15/Monat</strong> (= €180/Jahr) im Jahresabo — das spart rund 21 %.</p>
