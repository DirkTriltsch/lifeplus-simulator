---
import type { Brand, PricingPage } from '@shared/content-schemas/config';

interface Props {
  brand: Brand;
  pricing: PricingPage;
  source?: string;
}
const { brand, pricing, source } = Astro.props;

const priceIdByKey = {
  monthly: brand.paddle.priceIdMonthly,
  halfyear: brand.paddle.priceIdHalfYear ?? '',
  yearly: brand.paddle.priceIdYearly,
};

const paddleConfig = {
  clientToken: brand.paddle.clientToken,
  env: brand.paddle.env,
  appUrl: brand.appUrl,
  brandId: brand.id,
  apiBaseUrl: brand.apiBaseUrl ?? '',
};
---

<!-- ===== Page hero ===== -->
<section
  class="ph"
  data-section="Pricing Hero"
  data-component-file="shared/components/sections/PricingPageDefault.astro"
  data-source={source}
>
  <div class="wrap">
    <div class="ph-eyebrow">{pricing.hero.eyebrow}</div>
    <h1 class="ph-h1" set:html={pricing.hero.h1Html} />
    <p class="ph-sub" set:html={pricing.hero.subHtml} />

    <div class="vat-banner-wrap">
      <div class="vat-banner">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          ><circle cx="12" cy="12" r="9" /><path d="M12 8v4M12 16h.01" stroke-linecap="round" /></svg
        >
        <div class="vat-banner-text">
          <strong>{pricing.vatBanner.title}</strong>
          <span>{pricing.vatBanner.body}</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ===== Pricing cards ===== -->
<section
  class="pricing-section"
  data-section="Pricing Cards"
  data-component-file="shared/components/sections/PricingPageDefault.astro"
  data-source={source}
>
  <div class="wrap">
    <div class="pricing-row">
      {pricing.tiers.map((tier) => (
        <div
          class={`price-card${tier.featured ? ' featured' : ''}`}
          data-section={`Pricing Card: ${tier.name}`}
          data-component-file="shared/components/sections/PricingPageDefault.astro"
          data-source={source}
        >
          {tier.badge && <div class="pc-badge">{tier.badge}</div>}
          <div class="price-name">{tier.name}</div>
          <div class="price-desc" set:html={tier.descHtml} />
          <div class="price-amount">
            <span class="price-cur">{tier.currency}</span>
            <span class="price-val">{tier.value}</span>
            <span class="price-unit">
              {tier.unit}
              {tier.unitNote && <em>{tier.unitNote}</em>}
            </span>
          </div>
          <div class="price-billed">{tier.billed}</div>
          <ul class="price-feats">
            {tier.features.map((f) => (
              <li>
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
                  ><polyline points="20 6 9 17 4 12" stroke-linecap="round" stroke-linejoin="round" /></svg
                >
                <span>
                  {f.strong && <strong>{f.strong}</strong>}
                  {f.strong ? ' ' : ''}{f.text}
                </span>
              </li>
            ))}
          </ul>
          {tier.cta.kind === 'link' ? (
            <a
              href={tier.cta.url === '/app/' ? brand.appUrl : tier.cta.url}
              class="price-cta"
              data-free-start={tier.id === 'free' && brand.apiBaseUrl ? 'true' : undefined}
            >
              {tier.cta.label}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                ><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" /></svg
              >
            </a>
          ) : (
            <button
              type="button"
              class="price-cta"
              data-plan={tier.cta.plan}
              data-price-id={priceIdByKey[tier.cta.priceIdKey]}
            >
              {tier.cta.label}
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                ><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" /></svg
              >
            </button>
          )}
        </div>
      ))}
    </div>

    {pricing.notes.map((note) => (
      <div class="pricing-note">
        {note.icon === 'info' ? (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            ><circle cx="12" cy="12" r="9" /><path d="M12 8v4M12 16h.01" stroke-linecap="round" /></svg
          >
        ) : (
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
            ><path d="M8 3h8l4 4v14H4V3h4z" /><path
              d="M16 3v5h5M8 13h8M8 17h6"
              stroke-linecap="round"
              stroke-linejoin="round"
            /></svg
          >
        )}
        <span>
          <span class="pricing-note-title">{note.title}</span>
          {note.body}
        </span>
      </div>
    ))}
  </div>
</section>

<!-- ===== Comparison ===== -->
<section
  class="compare"
  data-section="Pricing Vergleich"
  data-component-file="shared/components/sections/PricingPageDefault.astro"
  data-source={source}
>
  <div class="wrap">
    <h2 class="compare-h" set:html={pricing.compare.headlineHtml} />
    <p class="compare-sub">{pricing.compare.sub}</p>

    <div class="compare-table">
      <div class="compare-row header">
        <div></div>
        {pricing.compare.columns.map((col) => (
          <div class={`compare-cell${col.featured ? ' featured' : ''}`}>
            <span class={`compare-head-name${col.featured ? ' featured-name' : ''}`}>{col.name}</span>
            <span class="compare-head-sub">{col.sub}</span>
          </div>
        ))}
      </div>

      {pricing.compare.rows.map((row) => (
        <div class="compare-row">
          <div class="compare-feat">{row.feature}</div>
          {row.cells.map((cell, idx) => {
            const featured = pricing.compare.columns[idx]?.featured;
            const cls = `compare-cell${featured ? ' featured' : ''}`;
            if (cell === 'check') {
              return (
                <div class={cls}>
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
                    ><polyline
                      points="20 6 9 17 4 12"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    /></svg
                  >
                </div>
              );
            }
            return <div class={cls}>{cell === '-' ? '—' : cell}</div>;
          })}
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== FAQ ===== -->
<section
  class="faq-section"
  data-section="Pricing FAQ"
  data-component-file="shared/components/sections/PricingPageDefault.astro"
  data-source={source}
>
  <div class="wrap">
    <h2 class="faq-h" set:html={pricing.faq.headlineHtml} />
    <div class="faq-list">
      {pricing.faq.items.map((item, idx) => (
        <div class={`faq-item${idx === 0 ? ' open' : ''}`}>
          <button class="faq-q" type="button">
            <span>{item.q}</span>
            <span class="faq-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"
                ><path d="M12 5v14M5 12h14" stroke-linecap="round" /></svg
              >
            </span>
          </button>
          <div class="faq-a">
            <div class="faq-a-inner">
              {item.a.map((p) => <p set:html={p} />)}
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ===== Final CTA ===== -->
<section
  class="final-cta"
  id="cta"
  data-section="Pricing Final CTA"
  data-component-file="shared/components/sections/PricingPageDefault.astro"
  data-source={source}
>
  <div class="wrap">
    <h2 class="final-h" set:html={pricing.finalCta.headlineHtml} />
    <p class="final-sub">{pricing.finalCta.sub}</p>
    <div class="final-ctas">
      <a href={pricing.finalCta.ctaUrl ?? brand.appUrl} class="btn-primary">
        {pricing.finalCta.ctaLabel}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
          ><path d="M5 12h14M13 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round" /></svg
        >
      </a>
    </div>
  </div>
</section>

<script is:inline define:vars={{ paddleConfig }}>
  window.__PADDLE_CFG__ = paddleConfig;
</script>
<script>
  import { setupPaddleCheckout } from '@shared/scripts/paddleCheckout';
  type Cfg = Parameters<typeof setupPaddleCheckout>[0];
  const cfg = (window as unknown as { __PADDLE_CFG__: Cfg }).__PADDLE_CFG__;
  setupPaddleCheckout(cfg);

  // FAQ-Akkordeon (aus pricing.html uebernommen)
  document.querySelectorAll<HTMLButtonElement>('.faq-q').forEach((btn) => {
    btn.addEventListener('click', () => {
      const item = btn.parentElement;
      if (!item) return;
      const isOpen = item.classList.contains('open');
      document.querySelectorAll('.faq-item').forEach((i) => i.classList.remove('open'));
      if (!isOpen) item.classList.add('open');
    });
  });
</script>

<style>
  .wrap { max-width: 1240px; margin: 0 auto; padding: 0 28px; }
  @media (max-width: 720px) { .wrap { padding: 0 20px; } }

  :root {
    --serif: 'Fraunces', 'Source Serif 4', Georgia, serif;
    --sans: 'Inter', system-ui, -apple-system, sans-serif;
    --mono: 'JetBrains Mono', 'SF Mono', Menlo, monospace;
    --ink: #0F1B17;
    --ink-2: #2C4138;
    --ink-3: #4A5C53;
    --ink-4: #7A8983;
    --ink-5: #A8B2AD;
    --line: #E1E5E2;
    --line-soft: #EEF1EF;
    --paper: #FAFBF9;
    --paper-2: #F4F6F2;
  }

  body { font-family: var(--sans); color: var(--ink); background: var(--paper); line-height: 1.55; font-size: 16px; }
  .btn-primary::after { content: none; }

  /* ===== Page header ===== */
  .ph {
    padding: 84px 0 40px;
    text-align: center;
    background: radial-gradient(ellipse 700px 300px at 50% 0%, var(--brand-surface) 0%, transparent 70%);
  }
  .ph-eyebrow {
    display: inline-flex; align-items: center; gap: 8px;
    font-family: var(--mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--brand);
    margin-bottom: 22px;
    font-weight: 500;
  }
  .ph-eyebrow::before, .ph-eyebrow::after { content: ""; width: 24px; height: 1px; background: var(--brand); }
  .ph-h1 {
    font-family: var(--serif);
    font-size: clamp(38px, 5.2vw, 60px);
    line-height: 1.05;
    letter-spacing: -0.025em;
    font-weight: 400;
    color: var(--ink);
    margin: 0 0 18px;
  }
  .ph-h1 :global(em) { font-style: italic; color: var(--brand); }
  .ph-sub { font-size: 18px; color: var(--ink-3); max-width: 580px; margin: 0 auto; line-height: 1.6; }

  /* ===== USt.-Banner ===== */
  .vat-banner-wrap { padding: 18px 0 4px; }
  .vat-banner {
    max-width: 720px;
    margin: 0 auto;
    display: flex; gap: 14px; align-items: flex-start;
    padding: 16px 22px;
    background: var(--brand-surface);
    border: 1px solid color-mix(in srgb, var(--brand) 28%, var(--line));
    border-radius: 12px;
    line-height: 1.5;
  }
  .vat-banner svg { width: 22px; height: 22px; flex-shrink: 0; color: var(--brand); margin-top: 2px; }
  .vat-banner-text strong { display: block; color: var(--ink); font-weight: 600; font-size: 15px; margin-bottom: 4px; }
  .vat-banner-text span { display: block; color: var(--ink-3); font-size: 13px; }

  /* ===== Pricing cards ===== */
  .pricing-section { padding: 50px 0 88px; }
  .pricing-row {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 16px;
    max-width: 1240px;
    margin: 0 auto 28px;
    align-items: stretch;
  }
  @media (max-width: 1120px) { .pricing-row { grid-template-columns: repeat(2, minmax(0, 1fr)); max-width: 820px; } }
  @media (max-width: 640px) { .pricing-row { grid-template-columns: 1fr; max-width: 480px; } }

  .price-card {
    background: #fff;
    border: 0.5px solid var(--line);
    border-radius: 18px;
    padding: 34px 28px 30px;
    position: relative;
    transition: transform 0.2s, box-shadow 0.2s;
    display: flex;
    flex-direction: column;
  }
  .price-card:hover { transform: translateY(-4px); box-shadow: 0 8px 32px rgba(15,27,23,0.08); }
  .price-card.featured {
    border: 2px solid var(--brand);
    background: linear-gradient(180deg, white 0%, var(--brand-surface) 100%);
  }
  .pc-badge {
    position: absolute;
    top: -12px; left: 32px;
    background: var(--cta);
    color: #fff;
    font-family: var(--mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 5px 12px;
    border-radius: 100px;
    font-weight: 600;
    box-shadow: 0 2px 8px color-mix(in srgb, var(--cta) 32%, transparent);
  }
  .price-name { font-family: var(--serif); font-size: 24px; font-weight: 400; color: var(--ink); margin: 0 0 8px; letter-spacing: -0.01em; }
  .price-desc { font-size: 14px; line-height: 1.45; color: var(--ink-4); margin-bottom: 24px; min-height: 40px; }
  .price-amount { display: flex; align-items: baseline; gap: 4px; margin-bottom: 6px; letter-spacing: -0.025em; }
  .price-cur { font-family: var(--serif); font-size: 28px; color: var(--ink-3); font-weight: 300; }
  .price-val { font-family: var(--serif); font-size: clamp(48px, 4.3vw, 60px); color: var(--ink); font-weight: 400; line-height: 0.95; }
  .price-unit { font-family: var(--sans); font-size: 16px; color: var(--ink-4); margin-left: 8px; font-weight: 400; }
  .price-unit em { font-style: normal; font-size: 0.7em; color: var(--ink-4); margin-left: 4px; letter-spacing: 0.02em; }
  .price-billed {
    font-size: 13px; color: var(--ink-3);
    margin-bottom: 26px;
    padding-bottom: 22px;
    border-bottom: 0.5px solid var(--line-soft);
    min-height: 64px;
  }
  .price-card.featured .price-billed { color: var(--brand); font-weight: 500; }
  .price-feats { list-style: none; display: grid; gap: 12px; margin: 0 0 26px; padding: 0; }
  .price-feats li { display: flex; gap: 12px; align-items: flex-start; font-size: 14px; color: var(--ink-2); line-height: 1.5; }
  .price-feats li svg { width: 16px; height: 16px; flex-shrink: 0; color: var(--brand); margin-top: 2px; }
  .price-feats li strong { color: var(--ink); font-weight: 600; }

  .price-cta {
    display: inline-flex; align-items: center; justify-content: center; gap: 10px;
    width: 100%;
    padding: 14px 22px;
    border-radius: 100px;
    font-size: 15px; font-weight: 500;
    transition: all 0.18s;
    text-decoration: none !important;
    cursor: pointer;
    font-family: inherit;
    margin-top: auto;
  }
  button.price-cta { background: transparent; }
  .price-card.featured button.price-cta { border: none; }
  .price-card:not(.featured) .price-cta {
    background: #fff;
    color: var(--ink);
    border: 1px solid var(--line);
  }
  .price-card:not(.featured) .price-cta:hover { border-color: var(--brand); color: var(--brand); }
  .price-card.featured .price-cta {
    background: var(--cta);
    color: #fff;
    box-shadow: 0 1px 2px color-mix(in srgb, var(--cta) 22%, transparent),
                0 4px 14px color-mix(in srgb, var(--cta) 20%, transparent);
  }
  .price-card.featured .price-cta:hover {
    background: var(--cta-dark);
    transform: translateY(-1px);
    box-shadow: 0 2px 4px color-mix(in srgb, var(--cta) 24%, transparent),
                0 8px 24px color-mix(in srgb, var(--cta) 28%, transparent);
  }
  .price-cta svg { width: 15px; height: 15px; transition: transform 0.18s; }
  .price-cta:hover svg { transform: translateX(3px); }

  .pricing-note {
    max-width: 860px;
    margin: 0 auto;
    display: flex; gap: 14px; align-items: flex-start;
    padding: 22px 26px;
    background: #fff;
    border: 0.5px solid var(--line);
    border-radius: 12px;
    font-size: 15px;
    color: var(--ink-3);
    line-height: 1.55;
    box-shadow: 0 12px 34px rgba(18, 24, 38, 0.06);
  }
  .pricing-note svg { width: 22px; height: 22px; flex-shrink: 0; color: var(--brand); margin-top: 2px; }
  .pricing-note strong { color: var(--ink); font-weight: 650; }
  .pricing-note-title {
    display: block;
    color: var(--ink);
    font-size: 17px;
    font-weight: 650;
    margin-bottom: 5px;
  }
  .pricing-note + .pricing-note { margin-top: 14px; }

  /* ===== Comparison table ===== */
  .compare {
    padding: 88px 0;
    background: var(--paper-2);
    border-top: 0.5px solid var(--line);
    border-bottom: 0.5px solid var(--line);
  }
  @media (max-width: 720px) { .compare { padding: 56px 0; } }
  .compare-h {
    font-family: var(--serif);
    font-size: clamp(28px, 3.4vw, 38px);
    font-weight: 400;
    text-align: center;
    letter-spacing: -0.02em;
    margin: 0 0 12px;
    color: var(--ink);
  }
  .compare-h :global(em) { font-style: italic; color: var(--brand); }
  .compare-sub { text-align: center; font-size: 16px; color: var(--ink-3); margin-bottom: 44px; }

  .compare-table {
    max-width: 880px;
    margin: 0 auto;
    background: #fff;
    border-radius: 16px;
    border: 0.5px solid var(--line);
    overflow: hidden;
  }
  .compare-row {
    display: grid;
    grid-template-columns: 1.65fr repeat(4, 0.9fr);
    gap: 12px;
    padding: 18px 28px;
    align-items: center;
    border-top: 0.5px solid var(--line-soft);
    font-size: 14px;
  }
  .compare-row.header { border-top: none; background: var(--paper-2); padding: 22px 28px; }
  .compare-feat { color: var(--ink-2); font-weight: 500; }
  .compare-cell { text-align: center; color: var(--ink-3); }
  .compare-cell.featured { background: color-mix(in srgb, var(--brand) 4%, transparent); }
  .compare-cell svg { width: 18px; height: 18px; color: var(--brand); margin: 0 auto; }
  .compare-head-name {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 400;
    color: var(--ink);
    letter-spacing: -0.01em;
  }
  .compare-head-name.featured-name { color: var(--brand); font-weight: 500; }
  .compare-head-sub {
    display: block;
    font-family: var(--mono);
    font-size: 10px;
    color: var(--ink-4);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-top: 4px;
    font-weight: 500;
  }
  @media (max-width: 540px) {
    .compare-table { overflow-x: auto; }
    .compare-row {
      min-width: 720px;
      grid-template-columns: 1.4fr repeat(4, 0.7fr);
      padding: 14px 16px;
      gap: 8px;
      font-size: 13px;
    }
    .compare-feat { font-size: 13px; }
    .compare-head-name { font-size: 15px; }
  }

  /* ===== FAQ ===== */
  .faq-section { padding: 88px 0; }
  @media (max-width: 720px) { .faq-section { padding: 56px 0; } }
  .faq-h {
    font-family: var(--serif);
    font-size: clamp(28px, 3.4vw, 38px);
    font-weight: 400;
    text-align: center;
    letter-spacing: -0.02em;
    margin: 0 0 44px;
    color: var(--ink);
  }
  .faq-h :global(em) { font-style: italic; color: var(--brand); }
  .faq-list { max-width: 760px; margin: 0 auto; border-top: 0.5px solid var(--line); }
  .faq-item { border-bottom: 0.5px solid var(--line); }
  .faq-q {
    width: 100%;
    text-align: left;
    padding: 22px 0;
    display: flex; justify-content: space-between; align-items: flex-start;
    gap: 24px;
    font-family: var(--sans);
    font-size: 16px;
    font-weight: 500;
    color: var(--ink);
    background: none; border: none; cursor: pointer;
    transition: color 0.15s;
  }
  .faq-q:hover { color: var(--brand); }
  .faq-icon {
    width: 22px; height: 22px;
    border: 1px solid var(--line);
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: all 0.2s;
    margin-top: 1px;
  }
  .faq-icon svg { width: 10px; height: 10px; transition: transform 0.25s; }
  .faq-item.open .faq-icon { background: var(--brand); border-color: var(--brand); color: #fff; }
  .faq-item.open .faq-icon svg { transform: rotate(45deg); }
  .faq-a { max-height: 0; overflow: hidden; transition: max-height 0.32s cubic-bezier(0.4, 0, 0.2, 1); }
  .faq-a-inner { padding: 0 32px 24px 0; font-size: 15px; line-height: 1.65; color: var(--ink-3); }
  .faq-a-inner p + p { margin-top: 10px; }
  .faq-item.open .faq-a { max-height: 480px; }

  /* ===== Final CTA ===== */
  .final-cta {
    padding: 88px 0;
    text-align: center;
    background: linear-gradient(180deg, var(--paper) 0%, var(--brand-surface) 100%);
    border-top: 0.5px solid var(--line);
    position: relative;
    overflow: hidden;
  }
  .final-cta::before {
    content: ""; position: absolute; inset: 0;
    background: radial-gradient(ellipse 500px 240px at 50% 100%, color-mix(in srgb, var(--brand) 14%, transparent) 0%, transparent 70%);
  }
  .final-h {
    font-family: var(--serif);
    font-size: clamp(30px, 4.4vw, 50px);
    line-height: 1.06;
    letter-spacing: -0.025em;
    font-weight: 400;
    color: var(--ink);
    margin: 0 auto 18px;
    max-width: 680px;
    position: relative;
  }
  .final-h :global(em) { font-style: italic; color: var(--brand); }
  .final-sub { font-size: 17px; color: var(--ink-3); max-width: 500px; margin: 0 auto 32px; line-height: 1.6; position: relative; }
