---
import type { Hero } from '@shared/content-schemas/config';
interface Props extends Hero { source?: string; }
const { eyebrow, claim, subClaim, ctaLabel, ctaUrl = '#', source } = Astro.props;
---
<section class="hero" data-section="HeroDefault.astro" data-source={source}>
  <div class="wrap">
    <span class="eyebrow">{eyebrow}</span>
    <h1>{claim}</h1>
    <p class="sub">{subClaim}</p>
    <a href={ctaUrl} class="cta">{ctaLabel}</a>
  </div>
</section>

<style>
  .hero {
    padding: var(--space-6) var(--space-3);
    text-align: center;
    background: linear-gradient(180deg, var(--brand), var(--brand-dark));
    color: #fff;
  }
  .wrap { max-width: var(--max-content); margin: 0 auto; }
  .eyebrow {
    display: inline-block;
    padding: .35rem .9rem;
    background: rgba(255,255,255,.15);
    border-radius: 999px;
    font-size: .85rem;
    letter-spacing: .04em;
    text-transform: uppercase;
  }
  h1 { font-size: clamp(1.8rem, 4.5vw, 3.2rem); margin: var(--space-2) 0 var(--space-2); }
  .sub { font-size: 1.15rem; opacity: .92; max-width: 42rem; margin: 0 auto var(--space-3); }
  .cta {
    display: inline-block;
    padding: .95rem 1.8rem;
    background: var(--cta);
    color: #fff;
    text-decoration: none;
    border-radius: var(--radius-md);
    font-weight: 600;
    transition: background .2s;
  }
  .cta:hover { background: var(--cta-dark); }
</style>
