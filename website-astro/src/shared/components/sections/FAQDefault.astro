---
import type { FAQ } from '@shared/content-schemas/config';
interface Props extends FAQ { source?: string; }
const { headline, items, source } = Astro.props;
---
<section class="faq" data-section="FAQDefault.astro" data-source={source}>
  <div class="wrap">
    <h2>{headline}</h2>
    <dl>
      {items.map((item) => (
        <div class="item">
          <dt>{item.q}</dt>
          <dd>{item.a}</dd>
        </div>
      ))}
    </dl>
  </div>
</section>

<style>
  .faq { padding: var(--space-6) var(--space-3); background: #fafafa; }
  .wrap { max-width: 48rem; margin: 0 auto; }
  h2 { text-align: center; color: var(--brand); margin-bottom: var(--space-4); }
  dl { margin: 0; }
  .item { background: #fff; padding: var(--space-3); border-radius: var(--radius-md); margin-bottom: var(--space-2); border: 1px solid #eee; }
  dt { font-weight: 600; color: #111; margin-bottom: .4rem; }
  dd { margin: 0; color: #555; }
</style>
