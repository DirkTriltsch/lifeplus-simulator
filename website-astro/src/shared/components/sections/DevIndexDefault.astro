---
import type { Brand, BrandId } from '@shared/content-schemas/config';
import { BRAND_IDS } from '@shared/content-schemas/config';

interface Props { brand: Brand; source?: string; }
const { brand, source } = Astro.props;

const pages = [
  { href: 'index.html?debug=1', label: 'Startseite', file: `brands/${brand.id}/pages/index.astro`, comp: 'IndexPageDefault.astro', source: `brands/${brand.id}/brand.yaml` },
  { href: 'features.html?debug=1', label: 'Funktionen', file: `brands/${brand.id}/pages/features.astro`, comp: 'FeaturesPageDefault.astro', source: `brands/${brand.id}/brand.yaml` },
  { href: 'pricing.html?debug=1', label: 'Preise', file: `brands/${brand.id}/pages/pricing.astro`, comp: 'PricingPageDefault.astro', source: `brands/${brand.id}/content/pricing.yaml` },
  { href: 'mein-konto.html?debug=1', label: 'Mein Konto', file: `brands/${brand.id}/pages/mein-konto.astro`, comp: 'AccountPageDefault.astro', source: `brands/${brand.id}/brand.yaml` },
  { href: 'impressum.html?debug=1', label: 'Impressum', file: `brands/${brand.id}/pages/impressum.astro`, comp: 'LegalImpressumDefault.astro', source: 'shared/lib/contact.ts' },
  { href: 'datenschutz.html?debug=1', label: 'Datenschutz', file: `brands/${brand.id}/pages/datenschutz.astro`, comp: 'LegalDatenschutzDefault.astro', source: 'shared/lib/contact.ts' },
  { href: 'agb.html?debug=1', label: 'AGB', file: `brands/${brand.id}/pages/agb.astro`, comp: 'LegalAgbDefault.astro', source: 'shared/lib/contact.ts' },
  { href: 'widerruf.html?debug=1', label: 'Widerruf', file: `brands/${brand.id}/pages/widerruf.astro`, comp: 'LegalWiderrufDefault.astro', source: 'shared/lib/contact.ts' },
];

const reviewTargets = [
  { href: 'index.html?debug=1', label: 'Header im Seitenkontext', file: 'shared/components/layout/Header.astro', source: `brands/${brand.id}/brand.yaml` },
  { href: 'index.html?debug=1', label: 'Footer im Seitenkontext', file: 'shared/components/layout/Footer.astro', source: 'shared/lib/contact.ts' },
  { href: 'pricing.html?debug=1', label: 'Pricing mit Paddle-Flow', file: 'shared/components/sections/PricingPageDefault.astro', source: `brands/${brand.id}/content/pricing.yaml` },
  { href: 'mein-konto.html?debug=1', label: 'Account / Magic-Link', file: 'shared/components/sections/AccountPageDefault.astro', source: `brands/${brand.id}/brand.yaml` },
];

const otherBrands: BrandId[] = BRAND_IDS.filter((b) => b !== brand.id);
const isProd = !import.meta.env.DEV;
---
<main
  class="dev-index"
  data-section="DevIndexDefault.astro"
  data-component-file="shared/components/sections/DevIndexDefault.astro"
  data-source={source}
>
  <div class="dev-wrap">
    <div class="dev-header">
      <span class="dev-tag">LOCAL DEBUG</span>
      <h1>Review-Index fuer Seiten und Komponenten</h1>
      <p class="dev-lead">
        Interne Uebersicht fuer die aktive Brand <strong>{brand.siteName}</strong>
        <span class="brand-id">({brand.id})</span>. Links oeffnen die Seite direkt mit aktivem Debug-Overlay.
      </p>

      {isProd && (
        <div class="dev-warning">
          <strong>Production-Build:</strong> <code>debug.html</code> ist gebaut, aber per <code>robots.txt</code> ausgeschlossen. Nicht aus der Navigation verlinken.
        </div>
      )}
    </div>

    <section class="dev-section">
      <h2>Alle HTML-Seiten</h2>
      <p class="dev-sec-lead">Direkte Review-Links auf alle gebauten Seiten dieser Brand.</p>
      <ul class="dev-list">
        {pages.map((p) => (
          <li>
            <a href={p.href}>
              <span class="dev-list-label">{p.label}</span>
              <span class="dev-list-path">{p.href}</span>
            </a>
            <span class="dev-list-meta">
              <code>{p.file}</code> -> <code>{p.comp}</code> · <code>{p.source}</code>
            </span>
          </li>
        ))}
      </ul>
    </section>

    <section class="dev-section">
      <h2>Wichtige Komponenten</h2>
      <p class="dev-sec-lead">Schnelleinstieg fuer typische Anpassungen: Layout, Pricing, Account und Content.</p>
      <ul class="dev-list">
        {reviewTargets.map((p) => (
          <li>
            <a href={p.href}>
              <span class="dev-list-label">{p.label}</span>
              <span class="dev-list-path">{p.href}</span>
            </a>
            <span class="dev-list-meta">
              <code>{p.file}</code> · <code>{p.source}</code>
            </span>
          </li>
        ))}
      </ul>
    </section>

    <section class="dev-section">
      <h2>Debug-Modus</h2>
      <p class="dev-sec-lead">
        Komponenten sind mit <code>data-section</code>, <code>data-component-file</code> und <code>data-source</code> annotiert.
      </p>
      <div class="dev-cmd">
        <kbd>d</kbd>
        <span>Debug-Outlines toggeln. Links oben: Komponenten-Datei. Rechts oben: verknuepfte Content-, Config- oder Lib-Dateien als VS-Code-Links.</span>
      </div>
      <p class="dev-note">
        Alternativ <code>?debug=1</code> anhaengen. Ausschalten mit <code>?debug=0</code>.
      </p>
    </section>

    <section class="dev-section">
      <h2>Andere Brands</h2>
      <p class="dev-sec-lead">Jede Brand baut mit eigenem <code>ASTRO_BRAND</code>. Wechsel erfordert einen eigenen Dev-Server.</p>
      <div class="dev-brand-grid">
        <div class="dev-brand-card current">
          <span class="dev-brand-status">aktiv</span>
          <span class="dev-brand-name">{brand.siteName}</span>
          <span class="dev-brand-cmd"><code>npm run dev:{brand.id}</code></span>
        </div>
        {otherBrands.map((other) => (
          <div class="dev-brand-card">
            <span class="dev-brand-status">inaktiv</span>
            <span class="dev-brand-name">{other}</span>
            <span class="dev-brand-cmd"><code>npm run dev:{other}</code></span>
          </div>
        ))}
      </div>
    </section>

    <section class="dev-section">
      <h2>Build- und Deployment-Konfig</h2>
      <ul class="dev-meta">
        <li><span>Brand-ID</span><code>{brand.id}</code></li>
        <li><span>Site-Name</span><code>{brand.siteName}</code></li>
        <li><span>Site-Domain</span><code>{brand.siteDomain}</code></li>
        <li><span>App-URL</span><code>{brand.appUrl}</code></li>
        <li><span>API-Base</span><code>{brand.apiBaseUrl ?? 'nicht gesetzt'}</code></li>
        <li><span>Paddle-Env</span><code>{brand.paddle.env}</code></li>
        <li><span>Paddle-Token</span><code>{brand.paddle.clientToken.startsWith('REPLACE_') ? 'Platzhalter' : 'gesetzt'}</code></li>
        <li><span>Accent</span><code style={`color:${brand.accentColor}`}>{brand.accentColor}</code></li>
        <li><span>CTA</span><code style={`color:${brand.ctaColor}`}>{brand.ctaColor}</code></li>
      </ul>
    </section>
  </div>
</main>

<style>
  .dev-index { padding: 60px 0 120px; background: #fafbf9; min-height: 80vh; }
  .dev-wrap { max-width: 980px; margin: 0 auto; padding: 0 28px; }
  .dev-header { margin-bottom: 48px; }
  .dev-tag {
    display: inline-block;
    background: #d946ef;
    color: #fff;
    font-family: ui-monospace, 'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    padding: 4px 10px;
    border-radius: 4px;
    margin-bottom: 16px;
  }
  .dev-header h1 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: clamp(28px, 4vw, 42px);
    font-weight: 400;
    color: #0f1b17;
    margin: 0 0 12px;
    letter-spacing: -0.02em;
  }
  .dev-lead { font-size: 16px; color: #4a5c53; line-height: 1.55; margin: 0; }
  .dev-lead strong { color: var(--brand); font-weight: 600; }
  .brand-id { color: #7a8983; font-size: 14px; }
  .dev-warning {
    margin-top: 18px;
    padding: 14px 18px;
    background: #fef3c7;
    border-left: 3px solid #d97706;
    border-radius: 4px;
    color: #713f12;
    font-size: 14px;
    line-height: 1.55;
  }
  .dev-warning code,
  .dev-sec-lead code,
  .dev-note code {
    font-family: ui-monospace, monospace;
    background: #eef1ef;
    padding: 1px 5px;
    border-radius: 3px;
    font-size: 12px;
  }
  .dev-section { margin-bottom: 40px; }
  .dev-section h2 {
    font-family: 'Fraunces', Georgia, serif;
    font-size: 22px;
    font-weight: 400;
    color: #0f1b17;
    margin: 0 0 6px;
    letter-spacing: -0.01em;
  }
  .dev-sec-lead { font-size: 14px; color: #4a5c53; margin: 0 0 18px; line-height: 1.55; }
  .dev-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 8px; }
  .dev-list li {
    background: #fff;
    border: 0.5px solid #e1e5e2;
    border-radius: 8px;
    padding: 14px 18px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  .dev-list a { text-decoration: none; color: #0f1b17; display: flex; align-items: baseline; gap: 12px; flex-wrap: wrap; }
  .dev-list a:hover { color: var(--brand); }
  .dev-list-label { font-weight: 500; font-size: 15px; }
  .dev-list-path { font-family: ui-monospace, monospace; font-size: 12px; color: #7a8983; }
  .dev-list-meta { font-size: 11px; color: #7a8983; }
  .dev-list-meta code { font-family: ui-monospace, monospace; background: #eef1ef; padding: 1px 5px; border-radius: 3px; }
  .dev-cmd {
    display: flex; align-items: center; gap: 14px;
    background: #fff;
    border: 0.5px solid #e1e5e2;
    border-radius: 8px;
    padding: 16px 18px;
  }
  .dev-cmd kbd {
    display: inline-block;
    background: #0f1b17;
    color: #fff;
    padding: 4px 10px;
    border-radius: 6px;
    font-family: ui-monospace, monospace;
    font-size: 14px;
    box-shadow: 0 2px 0 #4a5c53;
  }
  .dev-cmd span { font-size: 14px; color: #2c4138; line-height: 1.5; }
  .dev-note { font-size: 12px; color: #7a8983; margin-top: 10px; }
  .dev-brand-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 10px; }
  .dev-brand-card {
    background: #fff;
    border: 0.5px solid #e1e5e2;
    border-radius: 8px;
    padding: 14px 16px;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }
  .dev-brand-card.current { border-color: var(--brand); background: color-mix(in srgb, var(--brand) 4%, white); }
  .dev-brand-status {
    font-family: ui-monospace, monospace;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #7a8983;
  }
  .dev-brand-card.current .dev-brand-status { color: var(--brand); font-weight: 600; }
  .dev-brand-name { font-weight: 600; font-size: 15px; }
  .dev-brand-cmd { font-size: 12px; color: #4a5c53; }
  .dev-brand-cmd code { font-family: ui-monospace, monospace; background: #eef1ef; padding: 1px 6px; border-radius: 3px; }
  .dev-meta { list-style: none; padding: 0; margin: 0; display: grid; gap: 6px; }
  .dev-meta li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 8px 14px;
    background: #fff;
    border: 0.5px solid #eef1ef;
    border-radius: 6px;
    font-size: 13px;
  }
  .dev-meta span { color: #7a8983; font-family: ui-monospace, monospace; font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; }
  .dev-meta code { font-family: ui-monospace, monospace; color: #0f1b17; }
</style>
