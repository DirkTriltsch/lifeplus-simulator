---
import type { FinalCTA } from '@shared/content-schemas/config';
interface Props extends FinalCTA { source?: string; }
const { headline, body, ctaLabel, ctaUrl = '#', source } = Astro.props;
---
<section class="final" data-section="FinalCTADefault.astro" data-source={source}>
  <div class="wrap">
    <h2>{headline}</h2>
    <p>{body}</p>
    <a href={ctaUrl} class="cta">{ctaLabel}</a>
  </div>
</section>

<style>
  .final {
    padding: var(--space-6) var(--space-3);
    background: linear-gradient(180deg, var(--brand-dark), var(--brand));
    color: #fff;
    text-align: center;
  }
  .wrap { max-width: 42rem; margin: 0 auto; }
  h2 { color: #fff; font-size: clamp(1.6rem, 3.5vw, 2.4rem); }
  p { color: rgba(255,255,255,.92); font-size: 1.1rem; }
  .cta {
    display: inline-block;
    margin-top: var(--space-2);
    padding: 1rem 2rem;
    background: var(--cta);
    color: #fff;
    text-decoration: none;
    border-radius: var(--radius-md);
    font-weight: 600;
  }
  .cta:hover { background: var(--cta-dark); }
</style>
