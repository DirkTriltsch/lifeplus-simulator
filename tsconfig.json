{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "types": ["vitest/globals", "vite/client"],
    "paths": {
      "@mlm/simulator-core": ["./packages/simulator-core/src/index.ts"],
      "@mlm/simulator-goals": ["./packages/simulator-goals/src/index.ts"],
      "@mlm/simulator-realistic-growth": ["./packages/simulator-realistic-growth/src/index.ts"],
      "@mlm/product-lifeplus": ["./packages/product-lifeplus/src/index.ts"],
      "@mlm/product-fitline": ["./packages/product-fitline/src/index.ts"],
      "@mlm/product-eqology": ["./packages/product-eqology/src/index.ts"],
      "@mlm/product-registry": ["./packages/product-registry/src/index.ts"]
    }
  },
  "include": ["website", "simulator-app", "packages", "tests"],
  "exclude": ["**/vite.config.ts", "vitest.config.ts"]
}
